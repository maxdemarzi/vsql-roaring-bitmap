# Test roaring64 common methods for ROARING64 custom type

INSTALL EXTENSION vsql_roaring_bitmap;
Query OK, 0 rows affected (0.00 sec)

SELECT roaring64_add(
  ROARING64::from_string('{1,2}'),
  3
) AS added_bitmap;
+--------------+
| added_bitmap |
+--------------+
| {1,2,3}      |
+--------------+
1 row in set (0.00 sec)

SELECT roaring64_remove(
  ROARING64::from_string('{1,2,3}'),
  2
) AS removed_bitmap;
+----------------+
| removed_bitmap |
+----------------+
| {1,3}          |
+----------------+
1 row in set (0.00 sec)

SELECT roaring64_contains(
  ROARING64::from_string('{1,2,3}'),
  2
) AS contains_two;
+--------------+
| contains_two |
+--------------+
|            1 |
+--------------+
1 row in set (0.00 sec)

SELECT roaring64_contains(
  ROARING64::from_string('{1,2,3}'),
  5
) AS contains_five;
+---------------+
| contains_five |
+---------------+
|             0 |
+---------------+
1 row in set (0.00 sec)

SELECT roaring64_cardinality(
  ROARING64::from_string('{1,2,3,4,5}')
) AS card;

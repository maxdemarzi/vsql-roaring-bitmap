# Test k-hop reachable count using ROARING64 in a stored procedure

INSTALL EXTENSION vsql_roaring_bitmap;
Query OK, 0 rows affected (0.00 sec)

DROP PROCEDURE IF EXISTS roaring64_khops;
Query OK, 0 rows affected (0.00 sec)

DROP TABLE IF EXISTS graph_edges;
Query OK, 0 rows affected (0.00 sec)

CREATE TABLE graph_edges (src BIGINT, dst BIGINT);
Query OK, 0 rows affected (0.00 sec)

INSERT INTO graph_edges VALUES
  (1, 2), (2, 1),
  (1, 3), (3, 1),
  (2, 4), (4, 2),
  (3, 5), (5, 3),
  (5, 6), (6, 5);
Query OK, 10 rows affected (0.00 sec)

CALL roaring64_khops(1, 1, @reachable);
Query OK, 0 rows affected (0.00 sec)

SELECT @reachable AS reachable_1;
+-------------+
| reachable_1 |
+-------------+
|           2 |
+-------------+
1 row in set (0.00 sec)

CALL roaring64_khops(1, 2, @reachable);
Query OK, 0 rows affected (0.00 sec)

SELECT @reachable AS reachable_2;
+-------------+
| reachable_2 |
+-------------+
|           4 |
+-------------+
1 row in set (0.00 sec)

CALL roaring64_khops(1, 3, @reachable);
Query OK, 0 rows affected (0.00 sec)

SELECT @reachable AS reachable_3;
+-------------+
| reachable_3 |
+-------------+
|           5 |
+-------------+
1 row in set (0.00 sec)

UNINSTALL EXTENSION vsql_roaring_bitmap;

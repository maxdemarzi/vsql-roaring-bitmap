# Test roaring64_union for ROARING64 custom type

INSTALL EXTENSION vsql_roaring_bitmap;
Query OK, 0 rows affected (0.00 sec)

SELECT roaring64_union(
  CAST('{1,2,3}' AS ROARING64),
  CAST('{3,4,5}' AS ROARING64)
) AS union_bitmap;
+--------------+
| union_bitmap |
+--------------+
| {1,2,3,4,5}  |
+--------------+
1 row in set (0.00 sec)

UNINSTALL EXTENSION vsql_roaring_bitmap;
